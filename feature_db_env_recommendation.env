# ============================================================
# Feature DB 新增環境變數
# ============================================================
PREDICT_MODE=hybrid
USE_PATTERN_FEATURE_DB=1
USE_AI_POINT_FEATURE_DB=1
FEATURE_DB_FALLBACK_TO_HISTORY=1
FEATURE_DB_MIN_SAMPLE=80
PATTERN_FEATURE_DB_PATH=pattern_feature_db.json
AI_POINT_FEATURE_DB_PATH=ai_point_feature_db.json

# ============================================================
# 建議搭配的權重
# pattern_feature_db 有資料後，PATTERN_WEIGHT 會優先給 feature pattern
# ai_point_feature_db 有資料後，SIM_WEIGHT 會優先給 feature AI
# 若 feature 查不到，hybrid 會退回原本 history rounds 模式
# ============================================================
POINT_WEIGHT=0.56
PATTERN_WEIGHT=0.31
SIM_WEIGHT=0.13

# ============================================================
# 進場 / 暖機 / Monte Carlo 建議
# ============================================================
MIN_HISTORY_FOR_ENTRY=3
MIN_GAP_FOR_ENTRY=0.035
STRONG_GAP_FOR_ENTRY=0.065
USE_MONTE_CARLO=1
MC_SIMULATIONS=300
MC_MIN_SIMULATIONS=80
MC_MAX_SIMULATIONS=800
MC_MAX_NOISE=0.018
MC_BLOCK_LOW_GAP=1
MC_MIN_GAP_FOR_ENTRY=0.035
MC_DIRECTION_MISMATCH_BLOCK=0
