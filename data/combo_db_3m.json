#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
generate_combo_db_3m.py

V9 專用：產生 data/combo_db_3m.json
邏輯：用 8 副牌百家樂補牌規則，連續模擬牌靴，統計：
    當局點數 + 當局補牌情境  ->  下一局莊 / 閒 機率

輸出 key 範例：
    P6_B5|SC:BOTH_DRAW
    P6_B5|SC:PLAYER_DRAW
    P6_B5|SC:BANKER_DRAW
    P6_B5|SC:NONE_DRAW
    P6_B5|BASE

使用方式：
    python generate_combo_db_3m.py

可調環境變數：
    COMBO_SIM_TRANSITIONS=3000000
    COMBO_DB_OUTPUT=data/combo_db_3m.json
    COMBO_DECKS=8
    COMBO_CUT_REMAINING=70
    COMBO_SEED=42
"""

from __future__ import annotations

import json
import os
import random
import time
from collections import defaultdict
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, List, Tuple


TARGET_TRANSITIONS = int(os.getenv("COMBO_SIM_TRANSITIONS", "3000000"))
OUTPUT_PATH = os.getenv("COMBO_DB_OUTPUT", "data/combo_db_3m.json")
DECKS = int(os.getenv("COMBO_DECKS", "8"))
CUT_REMAINING = int(os.getenv("COMBO_CUT_REMAINING", "70"))
SEED = int(os.getenv("COMBO_SEED", "42"))

SCENARIOS = ("NONE_DRAW", "PLAYER_DRAW", "BANKER_DRAW", "BOTH_DRAW")


@dataclass(frozen=True)
class RoundResult:
    player_point: int
    banker_point: int
    result: str  # "P" / "B" / "T"
    scenario: str
    player_draw: bool
    banker_draw: bool


def make_shoe(decks: int = 8) -> List[int]:
    """8 副牌：A=1, 2~9，10/J/Q/K=0。"""
    shoe: List[int] = []
    for _ in range(decks):
        # 每副牌：A~9 各 4 張；10/J/Q/K 共 16 張，點數都是 0。
        for v in range(1, 10):
            shoe.extend([v] * 4)
        shoe.extend([0] * 16)
    random.shuffle(shoe)
    return shoe


def total(cards: List[int]) -> int:
    return sum(cards) % 10


def draw_card(shoe: List[int]) -> int:
    return shoe.pop()


def banker_should_draw(banker_total: int, player_third: int | None) -> bool:
    """標準百家樂補牌規則。"""
    if player_third is None:
        return banker_total <= 5

    if banker_total <= 2:
        return True
    if banker_total == 3:
        return player_third != 8
    if banker_total == 4:
        return 2 <= player_third <= 7
    if banker_total == 5:
        return 4 <= player_third <= 7
    if banker_total == 6:
        return 6 <= player_third <= 7
    return False


def scenario_name(player_draw: bool, banker_draw: bool) -> str:
    if player_draw and banker_draw:
        return "BOTH_DRAW"
    if player_draw and not banker_draw:
        return "PLAYER_DRAW"
    if banker_draw and not player_draw:
        return "BANKER_DRAW"
    return "NONE_DRAW"


def play_round(shoe: List[int]) -> RoundResult:
    """從同一牌靴發一局百家樂，回傳最終點數與實際補牌情境。"""
    player = [draw_card(shoe), draw_card(shoe)]
    banker = [draw_card(shoe), draw_card(shoe)]

    p_total = total(player)
    b_total = total(banker)

    player_draw = False
    banker_draw = False
    player_third = None

    # Natural 8/9：雙方不補。
    if p_total not in (8, 9) and b_total not in (8, 9):
        if p_total <= 5:
            player_third = draw_card(shoe)
            player.append(player_third)
            player_draw = True
            p_total = total(player)

        if banker_should_draw(b_total, player_third):
            banker.append(draw_card(shoe))
            banker_draw = True
            b_total = total(banker)

    if p_total > b_total:
        result = "P"
    elif b_total > p_total:
        result = "B"
    else:
        result = "T"

    return RoundResult(
        player_point=p_total,
        banker_point=b_total,
        result=result,
        scenario=scenario_name(player_draw, banker_draw),
        player_draw=player_draw,
        banker_draw=banker_draw,
    )


def new_counter() -> Dict[str, int]:
    return {
        "count": 0,
        "next_player": 0,
        "next_banker": 0,
        "next_tie": 0,
        "no_tie_sample": 0,
    }


def update_counter(counter: Dict[str, int], next_result: str) -> None:
    counter["count"] += 1
    if next_result == "P":
        counter["next_player"] += 1
        counter["no_tie_sample"] += 1
    elif next_result == "B":
        counter["next_banker"] += 1
        counter["no_tie_sample"] += 1
    else:
        counter["next_tie"] += 1


def to_record(key: str, c: Dict[str, int]) -> Dict[str, object]:
    no_tie = int(c.get("no_tie_sample", 0))
    count = int(c.get("count", 0))
    next_banker = int(c.get("next_banker", 0))
    next_player = int(c.get("next_player", 0))
    next_tie = int(c.get("next_tie", 0))

    if no_tie > 0:
        b_rate = next_banker / no_tie
        p_rate = next_player / no_tie
    else:
        b_rate = 0.5
        p_rate = 0.5

    tie_rate = next_tie / count if count > 0 else 0.0

    return {
        "feature_key": key,
        "next_banker_rate": round(b_rate, 8),
        "next_player_rate": round(p_rate, 8),
        "next_tie_rate": round(tie_rate, 8),
        "banker_prob": round(b_rate, 8),
        "player_prob": round(p_rate, 8),
        "sample": no_tie,
        "sample_size": no_tie,
        "no_tie_sample": no_tie,
        "count": count,
        "next_banker": next_banker,
        "next_player": next_player,
        "next_tie": next_tie,
        "source": "BACCARAT_8_DECK_SHOE_TRANSITION_COMBO_DB_V9",
    }


def main() -> None:
    random.seed(SEED)
    start = time.time()

    counters: Dict[str, Dict[str, int]] = defaultdict(new_counter)
    transitions = 0
    shoes_used = 0

    shoe = make_shoe(DECKS)
    shoes_used += 1
    prev: RoundResult | None = None

    while transitions < TARGET_TRANSITIONS:
        # 至少保留足夠牌數，避免一局不夠發。
        if len(shoe) < CUT_REMAINING:
            shoe = make_shoe(DECKS)
            shoes_used += 1
            prev = None
            continue

        try:
            cur = play_round(shoe)
        except IndexError:
            shoe = make_shoe(DECKS)
            shoes_used += 1
            prev = None
            continue

        if prev is not None:
            pkey = f"P{prev.player_point}_B{prev.banker_point}"
            sc_key = f"{pkey}|SC:{prev.scenario}"
            base_key = f"{pkey}|BASE"
            plain_key = pkey

            update_counter(counters[sc_key], cur.result)
            update_counter(counters[base_key], cur.result)
            update_counter(counters[plain_key], cur.result)

            transitions += 1

            if transitions % 250000 == 0:
                elapsed = time.time() - start
                print(f"[combo_db] {transitions:,}/{TARGET_TRANSITIONS:,} transitions, records={len(counters)}, shoes={shoes_used}, elapsed={elapsed:.1f}s")

        prev = cur

    records = {key: to_record(key, c) for key, c in sorted(counters.items())}

    # 補空殼：確保 100 點數 * 4 情境 key 都存在；樣本不足時用 BASE 或中性補上。
    for p in range(10):
        for b in range(10):
            pkey = f"P{p}_B{b}"
            base_key = f"{pkey}|BASE"
            base_rec = records.get(base_key)
            for sc in SCENARIOS:
                key = f"{pkey}|SC:{sc}"
                if key not in records:
                    if base_rec:
                        rec = dict(base_rec)
                        rec["feature_key"] = key
                        rec["source"] = "BACCARAT_8_DECK_SHOE_TRANSITION_COMBO_DB_V9_BASE_BACKFILL"
                        # sample 保留 base 樣本，讓系統能查到，但 source 會標示是 base 回填。
                        records[key] = rec
                    else:
                        records[key] = {
                            "feature_key": key,
                            "next_banker_rate": 0.5,
                            "next_player_rate": 0.5,
                            "next_tie_rate": 0.0,
                            "banker_prob": 0.5,
                            "player_prob": 0.5,
                            "sample": 0,
                            "sample_size": 0,
                            "no_tie_sample": 0,
                            "count": 0,
                            "next_banker": 0,
                            "next_player": 0,
                            "next_tie": 0,
                            "source": "BACCARAT_8_DECK_SHOE_TRANSITION_COMBO_DB_V9_EMPTY_BACKFILL",
                        }

    db = {
        "meta": {
            "source": "BACCARAT_8_DECK_SHOE_TRANSITION_COMBO_DB_V9",
            "description": "Current round final points + actual draw scenario -> next round no-tie banker/player rates. Generated by standard baccarat drawing rules.",
            "total_simulated_samples": TARGET_TRANSITIONS,
            "transition_samples": TARGET_TRANSITIONS,
            "record_count": len(records),
            "decks": DECKS,
            "cut_remaining": CUT_REMAINING,
            "seed": SEED,
            "generated_at_unix": int(time.time()),
            "key_examples": [
                "P6_B5|SC:BOTH_DRAW",
                "P6_B5|SC:PLAYER_DRAW",
                "P6_B5|SC:BANKER_DRAW",
                "P6_B5|SC:NONE_DRAW",
                "P6_B5|BASE",
            ],
        },
        "records": records,
    }

    out = Path(OUTPUT_PATH)
    out.parent.mkdir(parents=True, exist_ok=True)
    tmp = out.with_suffix(out.suffix + ".tmp")
    with tmp.open("w", encoding="utf-8") as f:
        json.dump(db, f, ensure_ascii=False, separators=(",", ":"))
    tmp.replace(out)

    elapsed = time.time() - start
    print(f"[combo_db] done: {out} records={len(records)} transitions={TARGET_TRANSITIONS:,} shoes={shoes_used} elapsed={elapsed:.1f}s")


if __name__ == "__main__":
    main()
